{
  "name": "@sarxina/foxyjumpscare",
  "version": "0.1.1",
  "description": "A VTube Studio plugin that randomly triggers a jumpscare with a gif and sound",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prestart": "node scripts/copy-assets.mjs",
    "start": "tsx src/standalone.ts",
    "prebuild": "node scripts/copy-assets.mjs",
    "build": "tsc",
    "clean": "rm -rf dist assets"
  },
  "dependencies": {
    "@sarxina/sarxina-tools": "^0.1.5",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.20.0",
    "@types/node": "^22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sarxina/Random-VTuber-Toys"
  },
  "author": "Sarxina",
  "license": "ISC"
}

