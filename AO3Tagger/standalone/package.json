{
  "name": "@sarxina/ao3tagger",
  "version": "0.3.0",
  "description": "A VTube Studio plugin that displays AO3-style tags as an overlay on your model",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/standalone.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.56",
    "@sarxina/sarxina-tools": "^0.3.2",
    "dotenv": "^16.4.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sarxina/Random-VTuber-Toys"
  },
  "author": "Sarxina",
  "license": "ISC"
}
