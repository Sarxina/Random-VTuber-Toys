{
  "name": "@sarxina/getdown",
  "version": "0.1.0",
  "description": "VTube Studio plugins that make your model go unhinged — random movement generator and physics breaker",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/standalone.ts",
    "break": "tsx src/break_model.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sarxina/sarxina-tools": "^0.1.5",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.20.0",
    "@types/node": "^22.0.0"
  },
  "author": "Sarxina",
  "license": "ISC"
}
